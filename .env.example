# =====================================================
# AMBIENTE
# =====================================================

# development | production
ENV=development

# true apenas em desenvolvimento
DEBUG=true

# INFO | WARNING | ERROR
LOG_LEVEL=INFO


# =====================================================
# APLICAÇÃO
# =====================================================

NAME=ClimaGyn Backend Core
VERSION=2.0.0

# Host e porta usados pelo uvicorn
HOST=0.0.0.0
PORT=8000


# =====================================================
# BANCO DE DADOS
# =====================================================

# Exemplo PostgreSQL local
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/climagyn

# Configuração de pool
POOL_SIZE=5
MAX_OVERFLOW=10
ECHO_SQL=false


# =====================================================
# API DE IA (ICRA)
# =====================================================

# URL base da API de IA consumida pelo backend
BASE_URL=http://localhost:8501
TIMEOUT_SECONDS=30

MODEL_NAME=ICRA
MODEL_VERSION=v1.0


# =====================================================
# CLIMA
# =====================================================

# URLs públicas do Open-Meteo
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive

CLIMATE_TIMEOUT_SECONDS=20
CLIMATE_MAX_RETRIES=2

# Se usar OpenWeather como fallback
OPEN_WEATHER_API_KEY=YOUR_API_KEY_HERE
# Frontend (Vite) usa esta chave diretamente no browser
VITE_WEATHER_API_KEY=YOUR_API_KEY_HERE

PRIMARY_PROVIDER=open_meteo
FALLBACK_PROVIDER=


# =====================================================
# RISCO / SNAPSHOT
# =====================================================

# Ativa scheduler global
SCHEDULER_ENABLED=true

# Intervalo do ciclo (segundos)
SCHEDULE_INTERVAL_SECONDS=10800

# TTL do snapshot
SNAPSHOT_TTL_SECONDS=10800

# Permite fallback sob demanda
FALLBACK_ON_DEMAND=true


# =====================================================
# MAPA
# =====================================================

MAX_POINTS=120
DEFAULT_POINT_RADIUS_M=300


# =====================================================
# DADOS
# =====================================================

CRITICAL_POINTS_CSV_PATH=ai/data/metadata/pontos_criticos.csv


# =====================================================
# CORS
# =====================================================

# Ajuste para os domínios reais do frontend no ambiente alvo
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]


# =====================================================
# FRONTEND (VITE)
# =====================================================

# URL pública do backend usada no build/runtime do frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
